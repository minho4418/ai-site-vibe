# Supabase
# Settings → API 에서 가져오세요.
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGci..."

# 서버 전용 (절대 NEXT_PUBLIC_ 접두사 붙이지 말 것)
# Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY="eyJhbGci..."

# /api/cron/ingest 보호용 토큰. 아무 긴 문자열이면 OK (예: openssl rand -hex 32).
# Vercel 환경변수에도 같은 값을 설정해야 cron 이 호출 가능.
CRON_SECRET="change-me-to-a-long-random-string"

# 기사 한국어 AI 요약(서버 전용). https://console.groq.com → API Keys 에서 발급(무료).
# 없으면 요약 단계는 그냥 건너뛰고 RSS 원문 요약으로 폴백됨.
GROQ_API_KEY="gsk_..."
# (선택) 요약 모델 교체. 기본값 llama-3.1-8b-instant. 더 좋은 품질: llama-3.3-70b-versatile
# GROQ_MODEL="llama-3.1-8b-instant"
